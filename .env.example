# =============================================================
# VORA — Frontend Environment Variables (.env.example)
# =============================================================
# Copy this file to .env and fill in the values for your
# Supabase / Lovable Cloud project.
#
# These are PUBLIC / PUBLISHABLE keys only.
# They are safe to bundle into the frontend — they do NOT
# grant admin access.
#
# Backend / Edge Function secrets (SUPABASE_SERVICE_ROLE_KEY,
# LOVABLE_API_KEY, SERPAPI_KEY, PHOTOROOM_API_KEY, etc.) belong
# in Supabase Secrets, NOT in this file.
# =============================================================

# Required — your Supabase project URL
VITE_SUPABASE_URL=

# Preferred — the publishable (anon) key used by this project
VITE_SUPABASE_PUBLISHABLE_KEY=

# Lovable Cloud project ID (used to construct edge function URLs)
VITE_SUPABASE_PROJECT_ID=

# Legacy fallback — only used if VITE_SUPABASE_PUBLISHABLE_KEY is
# empty or undefined. Prefer VITE_SUPABASE_PUBLISHABLE_KEY above.
# VITE_SUPABASE_ANON_KEY=
